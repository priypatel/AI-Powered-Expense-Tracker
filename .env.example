MONGODB_URI=              # MongoDB Atlas connection string (mongodb+srv://<user>:<pass>@<cluster>/<dbname>?retryWrites=true&w=majority)
JWT_SECRET=               # Min 64-char random string — generate with: openssl rand -base64 48
GEMINI_API_KEY=           # Google AI Studio API key — get free key at: aistudio.google.com
NEXT_PUBLIC_APP_URL=      # Deployed app URL (https://your-app.vercel.app) or http://localhost:3000 for dev
